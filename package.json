{
  "name": "vaultbank",
  "version": "1.0.0",
  "description": "VaultBank - Full Stack Banking Application",
  "scripts": {
    "start:client": "cd client && npm start",
    "start:server": "cd server && npm start",
    "dev": "concurrently \"npm run start:client\" \"npm run start:server\"",
    "install:client": "cd client && npm install",
    "install:server": "cd server && npm install",
    "install:all": "npm run install:client && npm run install:server",
    "postinstall": "npm run install:client",
    "prebuild": "test -d client || echo 'No client folder, using root build'",
    "build": "cd client && npm run build",
    "vercel:build": "npm run build",
    "vercel:dev": "npm run dev"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.14",
    "autoprefixer": "^10.4.21",
    "concurrently": "^8.2.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.15"
  },
  "keywords": [
    "banking",
    "react",
    "express",
    "fullstack"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@craco/craco": "^5.9.0",
    "bcrypt": "^6.0.0",
    "csv-writer": "^1.6.0",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "fast-csv": "^4.3.6",
    "file-saver": "^2.0.5",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "papaparse": "^5.5.3",
    "pdfkit": "^0.17.2",
    "react-beautiful-dnd": "^13.1.1",
    "react-circular-progressbar": "^2.2.0",
    "react-confetti": "^6.4.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.14.2",
    "swiper": "^12.0.3",
    "table": "^6.9.0",
    "xlsx": "^0.18.5"
  },
  "main": "index.js",
  "engines": {
    "node": "18.x"
  }
}
